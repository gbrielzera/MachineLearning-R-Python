load("C:/Users/Usuario/Desktop/deveres/7 semestre/Machine Learning/.RData")
setwd("C:/Users/Usuario/Desktop/deveres/7 semestre/Machine Learning/R")
# ==========================================
# 0. Inicialização e Pacotes
# ==========================================
# Instale os pacotes abaixo caso não tenha algum instalado:
# install.packages(c("caret", "e1071", "ggplot2", "reshape2"))
library(caret)
library(ggplot2)
library(reshape2)
# Configurar semente para reprodutibilidade (Equivalente ao random_state=42)
set.seed(42)
# Atalho simples para juntar textos (Equivalente ao f"" do Python)
f <- function(...) {
return(paste0(...))
}
# ==========================================
# 1. Carregamento dos dados
# ==========================================
df <- read.csv('heart.csv', sep = ',', strip.white = TRUE)
# No R, para problemas de classificação, a variável alvo DEVE ser um fator (Factor)
df$doenca_cardiaca <- as.factor(df$doenca_cardiaca)
# ==========================================
# 2. Preparação e Divisão dos dados (80/20)
# ==========================================
train_index <- createDataPartition(df$doenca_cardiaca, p = 0.8, list = FALSE)
train_data <- df[train_index, ]
test_data  <- df[-train_index, ]
# ==========================================
# 3. Ajuste de Hiperparâmetros (GridSearchCV via e1071)
# ==========================================
# O caret + e1071 exige exatamente as colunas: fL, usekernel, adjust
param_grid_nb <- expand.grid(
fL = c(0, 1, 2),             # Fator de correção de Laplace (antigo 'laplace')
usekernel = c(FALSE, TRUE),  # Testa distribuição Gaussiana Pura vs Densidade Kernel
adjust = c(1)                # Padrão para ajuste de banda do Kernel
)
# Configuração da Validação Cruzada (cv=5)
train_control <- trainControl(
method = "cv",
number = 5
)
# Executando o treinamento usando o e1071 (método "nb") com Padronização inclusa
grid_nb <- train(
doenca_cardiaca ~ .,
data = train_data,
method = "nb",                     # "nb" ativa internamente o pacote e1071
trControl = train_control,
tuneGrid = param_grid_nb,
preProcess = c("center", "scale"), # Aplica o StandardScaler idêntico ao Python
metric = "Accuracy"
)
# ==========================================
# 4. Avaliação e Previsões
# ==========================================
previsoes <- predict(grid_nb, newdata = test_data)
# Calculando a Matriz de Confusão detalhada
matriz_detalhada <- confusionMatrix(previsoes, test_data$doenca_cardiaca)
matriz <- matriz_detalhada$table
# Calculando a Acurácia de Teste (em %)
acuracia_teste <- matriz_detalhada$overall["Accuracy"] * 100
# ==========================================
# 5. Visualização Gráfica (Matriz de Confusão)
# ==========================================
matriz_melted <- melt(matriz)
colnames(matriz_melted) <- c("Previsto", "Real", "Valor")
levels(matriz_melted$Previsto) <- c("Saudável", "Doente")
levels(matriz_melted$Real) <- c("Saudável", "Doente")
ggplot(data = matriz_melted, aes(x = Previsto, y = Real, fill = Valor)) +
geom_tile(color = "white") +
scale_fill_gradient(low = "#e3f2fd", high = "#0d47a1") +
geom_text(aes(label = Valor), color = "black", size = 5) +
labs(
title = "Matriz de Confusão: Naive Bayes (e1071 Otimizado)",
x = "Previsto pela IA",
y = "Realidade (Médico)"
) +
theme_minimal() +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
# ==========================================
# 6. Impressão Formatada dos Resultados
# ==========================================
cat("\n", paste(rep("=", 60), collapse = ""), "\n")
cat(sprintf("%45s\n", "RELATÓRIO TÉCNICO: NAIVE BAYES (R - e1071)"))
cat(paste(rep("=", 60), collapse = ""), "\n")
cat("\n[CONFIGURAÇÃO DO MODELO]\n")
cat(f("Melhor configuração 'fL' (Laplace) encontrada: ", grid_nb$bestTune$fL, "\n"))
cat(f("Usou estimativa Kernel? ", grid_nb$bestTune$usekernel, "\n"))
cat(f("Acurácia média na Validação Cruzada: ", round(max(grid_nb$results$Accuracy), 4), "\n"))
cat("\n[DESEMPENHO NO TESTE]\n")
cat(f("Acurácia Geral: ", round(acuracia_teste, 2), "%\n"))
cat("\nMatriz de Confusão:\n")
cat(paste(rep("-", 60), collapse = ""), "\n")
# Transpõe para alinhar "Real" nas linhas e "Previsto" nas colunas como no Python
matriz_alinhada <- t(matriz)
df_cm <- as.data.frame.matrix(matriz_alinhada)
rownames(df_cm) <- c("Real: Saudável", "Real: Doente")
colnames(df_cm) <- c("Previsto: Saudável", "Previsto: Doente")
print(df_cm)
cat(paste(rep("-", 60), collapse = ""), "\n")
cat("\nRelatório de Métricas Detalhadas:\n")
metricas <- matriz_detalhada$byClass[, c("Precision", "Recall", "F1")]
